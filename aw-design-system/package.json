{
  "name": "aw-design-system",
  "version": "0.0.1",
  "description": "Stencil Component Starter",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/aw-design-system/aw-design-system.esm.js",
  "exports": {
    ".": {
      "import": "./dist/aw-design-system/aw-design-system.esm.js",
      "require": "./dist/aw-design-system/aw-design-system.cjs.js"
    },
    "./my-component": {
      "import": "./dist/components/my-component.js",
      "types": "./dist/components/my-component.d.ts"
    },
    "./loader": {
      "import": "./loader/index.js",
      "require": "./loader/index.cjs",
      "types": "./loader/index.d.ts"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/stenciljs/component-starter.git"
  },
  "files": [
    "dist/",
    "loader/"
  ],
  "scripts": {
    "build": "stencil build",
    "start": "stencil build --dev --watch --serve",
    "test": "stencil-test",
    "test:watch": "stencil-test --watch",
    "generate": "stencil generate",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "stencil build && storybook build && cp -R dist storybook-static/dist && cp -R loader storybook-static/loader",
    "tokens": "node scripts/build-tokens.js"
  },
  "devDependencies": {
    "@stencil/core": "^4.27.1 || ^5.0.0-0",
    "@stencil/vitest": "^1.8.3",
    "@storybook/addon-docs": "^10.3.6",
    "@storybook/web-components-vite": "^10.3.5",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.17",
    "@vitest/browser-playwright": "^4.0.0",
    "playwright": "^1.52.0",
    "storybook": "^10.3.5",
    "vite": "^8.0.10",
    "vitest": "^4.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "lit": "^3.3.2"
  }
}
